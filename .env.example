# Skopiuj ten plik do `.env` i wypełnij.
# .env NIE jest commitowany (patrz .gitignore).

# --- Vertex AI ---
VERTEX_PROJECT_ID=vertex-wfirma-dev
VERTEX_LOCATION=europe-west9
MODEL_NAME=gemini-2.5-pro

# Ścieżka do JSON service account key WEWNĄTRZ kontenera `api`.
# Fizycznie plik leży w ./secrets/ i jest mountowany jako /secrets/ (read-only).
GOOGLE_APPLICATION_CREDENTIALS=/secrets/vertex-wfirma-dev-ea19981c2c30.json

# --- Legal corpus refresh ---
# Maksymalny wiek korpusu zanim log ostrzeże o nieaktualności (dni).
LEGAL_CORPUS_MAX_AGE_DAYS=30

# Czy próbować odświeżenia korpusu przy starcie API.
# Jak false → zawsze użyje fallback/.
LEGAL_CORPUS_REFRESH_ON_STARTUP=true
