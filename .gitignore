# secrets — service account keys, .env
secrets/*
!secrets/.gitkeep
.env
.env.local

# legal corpus: raw/ to volatile working copy,
# fallback/ is committed and tracked
legal_sources/raw/*
!legal_sources/raw/.gitkeep

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.venv/
venv/

# node / frontend (na wszelki wypadek)
node_modules/
dist/
.parcel-cache/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# build artifacts
*.pdf
!legal_sources/**/*.pdf
